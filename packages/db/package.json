{
  "name": "@sfos/db",
  "version": "0.0.0",
  "private": true,
  "description": "PostgreSQL foundation: Drizzle schema, migrations, RLS helpers, and tenant context for SmartFactory OS.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    },
    "./context": {
      "types": "./dist/context.d.ts",
      "import": "./dist/context.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "files": ["dist", "src", "drizzle", "docker-compose.yml", ".env.example"],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "clean": "rimraf dist .turbo",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d",
    "db:psql": "docker compose exec postgres psql -U postgres -d sfos_dev",
    "db:migrate": "node --experimental-strip-types ./scripts/migrate.ts",
    "db:generate": "drizzle-kit generate",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@sfos/contracts": "workspace:*",
    "@sfos/events": "workspace:*",
    "drizzle-orm": "^0.36.0",
    "postgres": "^3.4.4"
  },
  "devDependencies": {
    "@sfos/eslint-config": "workspace:*",
    "@sfos/tsconfig": "workspace:*",
    "@types/node": "^20.16.10",
    "drizzle-kit": "^0.28.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.0"
  }
}
