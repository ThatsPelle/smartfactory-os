# SmartFactory OS — @sfos/db environment.
#
# Copy to .env (gitignored) and edit. The compose file in this directory uses
# the POSTGRES_* values to provision the local cluster; the application reads
# DATABASE_URL (tenant role) and DATABASE_ADMIN_URL (migrations / smoke).

# ----- docker compose service vars (consumed by docker-compose.yml) -----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sfos_dev

# ----- application connections -----
# Tenant role: RLS-bound. Use for everything that handles tenant data.
DATABASE_URL=postgres://app_tenant:app_tenant@localhost:5432/sfos_dev

# Admin role: BYPASSRLS. Use ONLY for migrations and the adversarial test
# harness (which needs to seed cross-tenant rows in order to attack them).
DATABASE_ADMIN_URL=postgres://postgres:postgres@localhost:5432/sfos_dev

# ----- adversarial test runner -----
# Tests skip with a clear message when this is unset, so CI without a DB
# doesn't silently pass.
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/sfos_dev
