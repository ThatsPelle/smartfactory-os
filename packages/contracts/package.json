{
  "name": "@sfos/contracts",
  "version": "0.0.0",
  "private": true,
  "description": "Frozen platform contracts: event envelope, manifest schema, branded primitives, well-known permission and capability keys.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./envelope": {
      "types": "./dist/envelope.d.ts",
      "import": "./dist/envelope.js"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js"
    },
    "./brands": {
      "types": "./dist/brands.d.ts",
      "import": "./dist/brands.js"
    },
    "./permissions": {
      "types": "./dist/permissions.d.ts",
      "import": "./dist/permissions.js"
    },
    "./capabilities": {
      "types": "./dist/capabilities.d.ts",
      "import": "./dist/capabilities.js"
    },
    "./result": {
      "types": "./dist/result.d.ts",
      "import": "./dist/result.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@sfos/eslint-config": "workspace:*",
    "@sfos/tsconfig": "workspace:*",
    "typescript": "^5.6.2",
    "rimraf": "^6.0.1"
  }
}
