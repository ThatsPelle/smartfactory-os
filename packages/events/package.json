    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@sfos/eslint-config": "workspace:*",
    "@sfos/tsconfig": "workspace:*",
    "typescript": "^5.6.2",
    "rimraf": "^6.0.1"
  }
}
