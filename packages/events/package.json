{
  "name": "@sfos/events",
  "version": "0.0.0",
  "private": true,
  "description": "Event envelope builders, naming validators, and ULID helpers atop @sfos/contracts.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
